{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Flask Debug (dev)",
            "type": "debugpy",
            "request": "launch",
            "module": "flask",
            "cwd": "${workspaceFolder}/app",
            "args": [
                "run",
                "--host",
                "0.0.0.0",
                "--port",
                "5000"
            ],
            "jinja": true,
            "env": {
                "FLASK_APP": "run.py",
                "FLASK_ENV": "development",
                "PORT": "5000",
                "FLASK_DEBUG": "1",
                "MYSQL_HOST": "db",
                "MYSQL_DATABASE": "repairdb",
                "MYSQL_USER": "root",
                "MYSQL_PASSWORD": "mariadb",
                "APP_SECRET": "dev-secret-key",
                "CUPS_SERVER": "172.19.0.1",
                "LABEL_PRINTER_NAME": "SII_SLP650",
                "LABEL_PRINT_METHOD": "cups"
            },
            "console": "integratedTerminal",
            "justMyCode": false
        },
        {
            "name": "Flask Debug (prod)",
            "type": "debugpy",
            "request": "launch",
            "module": "flask",
            "cwd": "${workspaceFolder}/app",
            "args": [
                "run",
                "--host",
                "0.0.0.0",
                "--port",
                "5000",
                "--no-reload"
            ],
            "jinja": true,
            "env": {
                "FLASK_APP": "api.py",
                "FLASK_ENV": "development",
                "FLASK_DEBUG": "1",
                "MYSQL_HOST": "db",
                "MYSQL_DATABASE": "repaircafepage",
                "MYSQL_USER": "root",
                "MYSQL_PASSWORD": "mariadb",
                "APP_SECRET": "dev-secret-key"
            },
            "console": "integratedTerminal",
            "justMyCode": false
        },
        {
            "name": "Python: Direct (api.py)",
            "type": "debugpy",
            "request": "launch",
            "cwd": "${workspaceFolder}/app",
            "program": "api.py",
            "args": [
                "-c",
                "dev"
            ],
            "console": "integratedTerminal",
            "justMyCode": false,
            "env": {
                "PORT": "5000",
                "MYSQL_HOST": "db",
                "MYSQL_DATABASE": "reparicafepage",
                "MYSQL_USER": "root",
                "MYSQL_PASSWORD": "mariadb",
                "PAGE_PASSWORD": "admin",
                "APP_SECRET": "dev-secret-key"
            }
        }
    ]
}