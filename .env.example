# Copy this file to .env and fill in the values before running docker compose up.
# Never commit the .env file to version control.

# ── Database ──────────────────────────────────────────────────────────────────
MYSQL_DATABASE=repaircafepage
MYSQL_USER=repaircafe
MYSQL_PASSWORD=change_me
MYSQL_ROOT_PASSWORD=change_me_root

# ── Flask ─────────────────────────────────────────────────────────────────────
# Secret key for session signing – use a long random string in production.
FLASK_SECRET_KEY=change_me_secret

# ── Email export (optional) ───────────────────────────────────────────────────
EMAIL_ENABLED=false
MAIL_TOKEN=
MAIL_SENDER=
MAIL_SENDER_NAME=RepairCafe
EXPORT_MAIL_RECEIVER=
ZIP_PASSWORD=

# ── Label printer (optional) ──────────────────────────────────────────────────
# LABEL_PRINT_METHOD: file (USB device file), cups, or network (default: file)
# LABEL_PRINTER_DEVICE=/dev/usb/lp0
# LABEL_PRINTER_NAME=SLP650
# LABEL_PRINTER_IP=
# LABEL_PRINTER_PORT=9100
